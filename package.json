{
  "name": "youtube-downloader-electron",
  "version": "1.0.0",
  "description": "Simple YouTube Downloader using Electron and Angular",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "build:ui": "npm run build --prefix ui",
    "build:electron": "tsc && copy src-electron\\preload.cjs dist-electron\\preload.cjs",
    "build": "npm run build:ui && npm run build:electron",
    "start": "electron ."
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "youtube-dl-exec": "^3.1.5",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "electron": "^34.3.0",
    "typescript": "^5.7.3"
  }
}
