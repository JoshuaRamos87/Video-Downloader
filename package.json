{
  "name": "video-downloader-electron",
  "version": "4.5.0",
  "description": "Simple Video Downloader using Electron and Angular",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "build:ui": "npm run build --prefix ui",
    "build:electron": "tsc && copy src-electron\\preload.cjs dist-electron\\preload.cjs",
    "build": "npm run build:ui && npm run build:electron",
    "dist": "npm run build && electron-builder",
    "start": "electron ."
  },
  "build": {
    "appId": "com.video.downloader",
    "productName": "Video Downloader",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/youtube-dl-exec/bin/*",
      "**/node_modules/ffmpeg-static/ffmpeg.exe"
    ],
    "files": [
      "dist-electron/**/*",
      "ui/dist/ui/browser/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "icon": "ui/public/favicon.ico"
    }
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "youtube-dl-exec": "^3.1.5",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
