{
  "name": "video-downloader-electron",
  "version": "1.0.0",
  "description": "Simple Video Downloader using Electron and Angular",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "build:ui": "npm run build --prefix ui",
    "build:electron": "tsc && copy src-electron\\preload.cjs dist-electron\\preload.cjs",
    "build": "npm run build:ui && npm run build:electron",
    "dist": "npm run build && electron-builder",
    "start": "electron ."
  },
  "build": {
    "appId": "com.video.downloader",
    "productName": "Video Downloader",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "ui/dist/ui/browser/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "icon": "ui/public/favicon.ico"
    }
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "youtube-dl-exec": "^3.1.5",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "electron": "^34.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.3"
  }
}
